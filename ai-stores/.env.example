# Copy to `.env` and edit. docker-compose picks this up automatically.
#
#   cp .env.example .env
#   docker compose up --build

# ── Ports (host-side) ──────────────────────────────────────────────────
APP_PORT=8000
MONGO_PORT=27017

# ── Database ───────────────────────────────────────────────────────────
# One database holds EVERY store. Each store lives at /{handle}/{store} and its
# data is in its own {handle}__{store}_* collections (e.g. acme__coffee_items),
# alongside the platform users, store_registry, namespace_members and audit_log.
# Adding a store never changes this — it's a runtime action.
MDB_DB_NAME=ai_stores

# ── Admin bootstrap ────────────────────────────────────────────────────
# Consumed by manifest.json via {{env.*}} substitution — this becomes the
# platform SUPERUSER, seeded on first boot, with access to every namespace from
# /manage. Everyone else signs up at /signup and owns only their own handle.
# CHANGE THESE.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123

# ── mdb-engine secrets ────────────────────────────────────────────────
# MDB_ENGINE_MASTER_KEY encrypts app secrets at rest (/__mdb/secrets). It
# MUST be a base64-encoded 32-byte key. Generate one with:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
# (If left as-is, encryption is simply disabled with a warning — sessions
#  and auth still work.)
MDB_ENGINE_MASTER_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
# MDB_JWT_SECRET signs session JWTs — rotating it logs everyone out. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
MDB_JWT_SECRET=change-me-dev-only-jwt-secret-min-32-chars-long

# ── Deployment environment ─────────────────────────────────────────────
# Set G_NOME_ENV=production in any TLS/network-reachable deployment. It marks
# the admin session cookie `Secure` (browser only sends it over HTTPS) — the
# CSRF/session hardening described in SCALE.md. Leave blank for local HTTP dev,
# where a Secure cookie would never be sent back and you couldn't stay logged in.
G_NOME_ENV=

# ── Cloudinary (optional) ──────────────────────────────────────────────
# Leave blank to disable admin image/video uploads (routes return 503).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Lead notifications (optional) ──────────────────────────────────────
# Email a store owner the moment a new inquiry lands. Uses Resend's HTTP API.
# Leave RESEND_API_KEY blank to disable notifications entirely (no-op).
#   RESEND_API_KEY — from https://resend.com (platform-wide key).
#   RESEND_FROM    — a verified sender, e.g. "AI Stores <leads@yourdomain.com>".
#   NOTIFY_ENABLED — global kill switch (default true). Per-store toggle and an
#                    optional recipient override live in each store's dashboard.
RESEND_API_KEY=
RESEND_FROM=
NOTIFY_ENABLED=true

# ── Abuse protection (optional; sane defaults if unset) ────────────────
# Public inquiry + signup writes are throttled per-IP; AI chat and uploads per
# user. Bump these only if you have a legitimate high-volume use case.
INQUIRY_RATELIMIT_PER_MIN=5
INQUIRY_RATELIMIT_PER_HOUR=30
SIGNUP_RATELIMIT_PER_MIN=5
SIGNUP_RATELIMIT_PER_HOUR=20
AI_RATELIMIT_PER_MIN=20
UPLOAD_RATELIMIT_PER_MIN=30

# ── Namespaces & self-serve signup (optional; sane defaults if unset) ──
# INVITE_TTL_SECONDS   — lifetime of a namespace team-invite link (signed with
#   MDB_JWT_SECRET). Default 604800 = 7 days.
# MAX_STORES_PER_HANDLE — cap stores per owned handle to blunt signup abuse.
#   0 = unlimited (the superuser is never capped).
INVITE_TTL_SECONDS=604800
MAX_STORES_PER_HANDLE=0

# ── Per-store quotas (optional; 0 = unlimited for each) ────────────────
# Enforced on both the CRUD write path (QuotaMiddleware) and AI-driven creates;
# uploads are counted on the store's registry row. Return 409 at the cap. The
# superuser is capped too — these are content limits, not auth. Console shows
# per-store usage badges (e.g. "3 / 50 items").
MAX_ITEMS_PER_STORE=0
MAX_SECTIONS_PER_STORE=0
MAX_UPLOADS_PER_STORE=0

# ── Store lifecycle / cache sync (optional; sane defaults if unset) ────
# STORE_CACHE_TTL_SECONDS — backstop interval for refreshing the KNOWN_STORES
#   routing cache across workers (a store_registry change stream handles the
#   instant path on a replica set / Atlas; this covers standalone Mongo).
# PROVISION_STUCK_MINUTES — how long a store may sit in "provisioning" before
#   the reconciler (POST /manage/reconcile, and startup) retries or fails it.
STORE_CACHE_TTL_SECONDS=30
PROVISION_STUCK_MINUTES=10

# ── AI editor (Google Gemini) — conversational store editor ────────────
# Powers the admin chat widget via Gemini's structured-output (JSON) mode.
# The editor stays disabled (chat routes return 503) until GEMINI_API_KEY is
# set — the storefront never depends on it.
#   GEMINI_API_KEY — from https://aistudio.google.com/apikey. REQUIRED to
#     enable the editor. Keep it secret; never commit a real key.
#   GEMINI_MODEL — any generateContent-capable model. Default is the latest
#     flash (fast + cheap + strong at structured output). Swap freely, e.g.
#     `gemini-2.5-flash` (stable) or `gemini-3.1-pro-preview` (max quality).
#   GEMINI_FALLBACK_MODEL — retried once if GEMINI_MODEL 404s (e.g. a preview
#     model was renamed / isn't enabled for the key). Default gemini-2.5-flash.
#   GEMINI_MAX_RETRIES / GEMINI_RETRY_BACKOFF — transient-failure policy: retry
#     429/5xx/transport errors with exponential backoff (default 2 retries,
#     0.5s base). Set retries to 0 to disable.
#   GEMINI_TEMPERATURE — 0.0-1.0; low keeps edits precise and literal.
#   GEMINI_API_BASE / GEMINI_TIMEOUT — override only for proxies / slow links.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1
# GEMINI_MAX_RETRIES=2
# GEMINI_RETRY_BACKOFF=0.5
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GEMINI_TIMEOUT=60

# ── Observability ──────────────────────────────────────────────────────
# LOG_LEVEL controls app log verbosity. Every request gets an X-Request-ID
# (honoured from a proxy if present) and a structured access log line. Probes:
#   GET /healthz        — liveness (no dependencies).
#   GET /readyz         — readiness (pings Mongo; 503 if unreachable).
#   GET /manage/status  — superuser-only platform metrics snapshot.
LOG_LEVEL=INFO
